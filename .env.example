# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/eduquest

# Supabase (auth + storage)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# App-signed JWTs for student login-code sessions (not a Supabase key —
# generate with: python -c "import secrets; print(secrets.token_hex(32))")
APP_JWT_SECRET=

# Frontend origin — used to build the password-reset redirect link
FRONTEND_URL=http://localhost:3000

# AI
OPENAI_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=

# Google Document AI — cheap cross-check OCR pass alongside Mathpix (catches
# cases where Mathpix mis-crops a multi-line question raster image). Needs a
# GCP project with the Document AI API enabled, billing on, and a "Document
# OCR" processor created — its ID and region come from the processor's page.
# Document AI rejects plain API keys outright, so this must be a service
# account: IAM & Admin -> Service Accounts -> create one -> grant it
# "Document AI API User" -> Keys -> Add Key -> JSON. Paste that JSON file's
# content here as a SINGLE LINE (not a file path).
GOOGLE_APPLICATION_CREDENTIALS_JSON=
GOOGLE_DOCUMENT_AI_PROJECT_ID=
GOOGLE_DOCUMENT_AI_LOCATION=
GOOGLE_DOCUMENT_AI_PROCESSOR_ID=
